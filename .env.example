# ---- Gemini (Google AI Studio) ----
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ---- Upstash Vector ----
# Create a free index at https://console.upstash.com/vector
# IMPORTANT: create the index with dimension 768 and metric COSINE
UPSTASH_VECTOR_REST_URL=
UPSTASH_VECTOR_REST_TOKEN=

# ---- Upstash Redis (per-IP rate limiting) ----
# Create a free database at https://console.upstash.com/redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
